[Unit]
Description=Puma HTTP Server for template-api-rails-app (production)
After=network.target

[Service]
Environment=RAILS_ENV=production
EnvironmentFile=/etc/environment
WorkingDirectory=/home/deploy/apps/template-api-rails-app/production/current
ExecStart=/home/deploy/.rbenv/bin/rbenv exec bundle exec puma -C /home/deploy/apps/template-api-rails-app/production/shared/puma.rb
ExecReload=/bin/kill -TSTP $MAINPID
ExecStop=/bin/kill -TERM $MAINPID
RestartSec=1
Restart=on-failure

StandardOutput=append:/home/deploy/apps/template-api-rails-app/production/current/log/puma.access.log
StandardError=append:/home/deploy/apps/template-api-rails-app/production/current/log/puma.error.log

[Install]
WantedBy=multi-user.target
