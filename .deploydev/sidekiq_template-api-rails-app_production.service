[Unit]
Description=Sidekiq for template-api-rails-app (production)
After=multi-user.target

[Service]
Environment=RAILS_ENV=production
EnvironmentFile=/etc/environment
WorkingDirectory=/home/deploy/apps/template-api-rails-app/production/current
ExecStart=/home/deploy/.rbenv/bin/rbenv exec bundle exec sidekiq -e production -C /home/deploy/apps/template-api-rails-app/production/current/config/sidekiq.yml
ExecReload=/bin/kill -TSTP $MAINPID
ExecStop=/bin/kill -TERM $MAINPID
UMask=0002
RestartSec=1
Restart=on-failure

StandardOutput=append:/home/deploy/apps/template-api-rails-app/production/current/log/sidekiq.log
StandardError=append:/home/deploy/apps/template-api-rails-app/production/current/log/sidekiq.log

[Install]
WantedBy=multi-user.target
